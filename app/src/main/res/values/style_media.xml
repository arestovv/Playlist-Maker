<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="CustomTabLayout">
        <item name="tabTextAppearance">@style/CustomTabText</item>
        <item name="tabIndicatorColor">@color/tab_indicator_color</item>
        <item name="tabTextColor">@color/text_color</item>
        <item name="tabSelectedTextColor">@color/text_color</item>
        <item name="android:background">@color/background_media_screen</item>
    </style>

    <style name="CustomTabText">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
    </style>

    <style name="CreatePlaylistButton">
        <item name="android:textColor">@color/yp_white</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">16sp</item>
        <item name="cornerRadius">8dp</item>
        <item name="textAllCaps">false</item>
        <item name="android:backgroundTint">@color/button_create_playlist_color</item>
    </style>

    <style name="CustomTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxStrokeColor">@color/colors_box_stroke</item>
        <item name="boxBackgroundColor">@color/background_media_screen</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="hintEnabled">true</item>
        <item name="android:textColorHint">@color/text_color</item>
        <item name="hintTextColor">@color/text_color</item>
    </style>

    <style name="CustomTextInputEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:layout_height">54dp</item>
        <item name="android:gravity">center_vertical|start</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:inputType">text</item>
        <item name="android:textColor">@color/text_color</item>
    </style>

</resources>