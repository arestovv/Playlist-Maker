<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_navigation_graph"
    app:startDestination="@id/mediaFragment"
    >

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.arestov.playlistmaker.ui.settings.SettingsFragment"
        android:label="fragment_settings">
    </fragment>
    <fragment
        android:id="@+id/searchFragment"
        android:name="com.arestov.playlistmaker.ui.search.SearchFragment"
        android:label="fragment_search">
        <action
            android:id="@+id/action_searchFragment_to_playerFragment"
            app:destination="@id/playerFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"
            />
    </fragment>
    <fragment
        android:id="@+id/mediaFragment"
        android:name="com.arestov.playlistmaker.ui.media.MediaFragment"
        android:label="fragment_media">
        <action
            android:id="@+id/action_mediaFragment_to_playerFragment"
            app:destination="@id/playerFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"
            />
        <action
            android:id="@+id/action_mediaFragment_to_createPlaylistFragment"
            app:destination="@id/createPlaylistFragment" />
        <action
            android:id="@+id/action_mediaFragment_to_playlistInfoFragment"
            app:destination="@id/playlistInfoFragment" />
    </fragment>
    <fragment
        android:id="@+id/playerFragment"
        android:name="com.arestov.playlistmaker.ui.player.PlayerFragment"
        android:label="fragment_player">
        <action
            android:id="@+id/action_playerFragment_to_createPlaylistFragment"
            app:destination="@id/createPlaylistFragment" />
    </fragment>
    <fragment
        android:id="@+id/createPlaylistFragment"
        android:name="com.arestov.playlistmaker.ui.media.CreatePlaylistFragment"
        android:label="CreatePlaylistFragment">
        <argument
            android:name="playlistId"
            app:argType="integer" />
    </fragment>
    <fragment
        android:id="@+id/playlistInfoFragment"
        android:name="com.arestov.playlistmaker.ui.media.PlaylistInfoFragment"
        android:label="PlaylistInfoFragment">
        <argument
            android:name="playlistId"
            app:argType="integer" />
        <action
            android:id="@+id/action_playlistInfoFragment_to_playerFragment"
            app:destination="@id/playerFragment" />
        <action
            android:id="@+id/action_playlistInfoFragment_to_createPlaylistFragment"
            app:destination="@id/createPlaylistFragment" />
    </fragment>
</navigation>
